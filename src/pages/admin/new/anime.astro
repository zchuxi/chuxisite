---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getAllAnime, slugOf } from '../../../lib/anime';

const allAnime = await getAllAnime();
const existingSlugs = allAnime.map((a) => slugOf(a.data.titleCn));
const existingGenres = [...new Set(allAnime.flatMap((a) => a.data.genre))].sort();
---

<BaseLayout title="新增追番 · 管理后台" description="新增追番条目">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <Header />
  <main class="mx-auto max-w-2xl px-4 py-12 md:px-6">
    <a href="/admin" class="admin-back-link">&larr; 返回工作台</a>

    <h1 class="mt-6 font-[family-name:var(--font-display)] text-2xl font-bold text-[var(--color-text)]">
      新增追番
    </h1>

    <form id="new-form" class="mt-8 flex flex-col gap-6">
      <!-- titleCn -->
      <div class="form-group">
        <label for="field-title" class="form-label">名称 *</label>
        <input id="field-title" type="text" required class="form-input" autocomplete="off" />
        <p id="title-error" class="form-error hidden">名称不能为空</p>
      </div>

      <!-- slug -->
      <div class="form-group">
        <label for="field-slug" class="form-label">Slug</label>
        <input id="field-slug" type="text" class="form-input slug-input" autocomplete="off" />
        <p id="slug-error" class="form-error hidden">该 slug 已存在，请修改</p>
        <p class="form-hint">自动从名称派生，可手动修改</p>
      </div>

      <!-- titleJa -->
      <div class="form-group">
        <label for="field-titleja" class="form-label">日文名</label>
        <input id="field-titleja" type="text" class="form-input" autocomplete="off" />
      </div>

      <!-- status -->
      <div class="form-group">
        <label for="field-status" class="form-label">状态 *</label>
        <select id="field-status" class="form-select">
          <option value="" disabled selected>请选择</option>
          <option value="watching">在看</option>
          <option value="done">看完</option>
          <option value="plan">想看</option>
        </select>
        <p id="status-error" class="form-error hidden">请选择状态</p>
      </div>

      <!-- progress -->
      <div class="form-group">
        <label for="field-progress" class="form-label">观看进度</label>
        <input id="field-progress" type="number" min="0" value="0" class="form-input w-24" />
      </div>

      <!-- episodes -->
      <div class="form-group">
        <label for="field-episodes" class="form-label">总集数</label>
        <input id="field-episodes" type="number" min="0" class="form-input w-24" />
      </div>

      <!-- myRating -->
      <div class="form-group">
        <label for="field-rating" class="form-label">评分（0-10）</label>
        <input id="field-rating" type="number" min="0" max="10" step="1" placeholder="未评分" class="form-input w-24" />
        <p id="rating-error" class="form-error hidden">评分需为 0-10 的整数</p>
      </div>

      <!-- comment -->
      <div class="form-group">
        <label for="field-comment" class="form-label">短评</label>
        <textarea id="field-comment" rows="3" class="form-textarea"></textarea>
      </div>

      <!-- cover -->
      <div class="form-group">
        <label for="field-cover" class="form-label">封面 URL</label>
        <input id="field-cover" type="text" placeholder="https://" class="form-input" />
      </div>

      <!-- airDate -->
      <div class="form-group">
        <label for="field-airdate" class="form-label">播出日期</label>
        <input id="field-airdate" type="date" class="form-input w-48" />
      </div>

      <!-- genre -->
      <div class="form-group">
        <label class="form-label">类型标签</label>
        <div id="genre-container" class="flex flex-wrap items-center gap-2"></div>
        <div class="flex gap-2">
          <input id="genre-input" type="text" placeholder="添加类型…" class="form-input flex-1" list="genre-suggestions" />
          <datalist id="genre-suggestions">
            {existingGenres.map((g) => (
              <option value={g} />
            ))}
          </datalist>
          <button type="button" id="add-genre-btn" class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-primary)] px-4 text-sm font-semibold text-[var(--color-primary-fg)] transition hover:bg-[var(--color-primary-hover)]">
            添加
          </button>
        </div>
      </div>

      <!-- body -->
      <div class="form-group">
        <label for="field-body" class="form-label">正文（Markdown）</label>
        <textarea id="field-body" rows="8" class="form-textarea font-mono text-sm"></textarea>
      </div>

      <!-- 生成按钮 -->
      <div class="mt-4">
        <button type="submit" id="generate-btn" class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-primary)] px-6 font-semibold text-[var(--color-primary-fg)] transition hover:bg-[var(--color-primary-hover)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50">
          生成 frontmatter
        </button>
      </div>
    </form>

    <!-- 预览面板 -->
    <div id="preview-panel" class="preview-panel mt-8 hidden">
      <div class="flex items-center justify-between gap-2">
        <span class="form-label">Frontmatter</span>
        <div class="flex gap-2">
          <button type="button" id="copy-btn" class="inline-flex min-h-9 items-center rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-xs font-semibold text-[var(--color-text-muted)] transition hover:text-[var(--color-primary)]">
            复制
          </button>
          <button type="button" id="download-btn" class="inline-flex min-h-9 items-center rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 text-xs font-semibold text-[var(--color-text-muted)] transition hover:text-[var(--color-primary)]">
            下载 JSON
          </button>
        </div>
      </div>
      <pre id="preview-content" class="mt-3"></pre>
    </div>
  </main>
  <div class="mt-24">
    <Footer />
  </div>
</BaseLayout>

<script define:vars={{ existingSlugs, existingGenres }}>
  (function() {
    var SESSION_KEY = 'chuxi_admin_session';
    if (localStorage.getItem(SESSION_KEY) !== '1') {
      window.location.href = '/admin';
      return;
    }

    // DOM refs
    var titleEl = document.getElementById('field-title');
    var slugEl = document.getElementById('field-slug');
    var titlejaEl = document.getElementById('field-titleja');
    var statusEl = document.getElementById('field-status');
    var progressEl = document.getElementById('field-progress');
    var episodesEl = document.getElementById('field-episodes');
    var ratingEl = document.getElementById('field-rating');
    var commentEl = document.getElementById('field-comment');
    var coverEl = document.getElementById('field-cover');
    var airdateEl = document.getElementById('field-airdate');
    var bodyEl = document.getElementById('field-body');
    var form = document.getElementById('new-form');
    var genBtn = document.getElementById('generate-btn');
    var previewPanel = document.getElementById('preview-panel');
    var previewContent = document.getElementById('preview-content');
    var copyBtn = document.getElementById('copy-btn');
    var downloadBtn = document.getElementById('download-btn');
    var titleError = document.getElementById('title-error');
    var statusError = document.getElementById('status-error');
    var genreInput = document.getElementById('genre-input');
    var addGenreBtn = document.getElementById('add-genre-btn');
    var genreContainer = document.getElementById('genre-container');
    var ratingError = document.getElementById('rating-error');
    var slugError = document.getElementById('slug-error');

    if (!form || !genBtn) return;

    var autoSlugging = true;
    var genres = [];

    function renderGenreTags() {
      var html = '';
      for (var i = 0; i < genres.length; i++) {
        html += '<span class="form-chip" data-genre="' + genres[i] + '">' + genres[i] + '<button type="button" data-remove-genre="' + genres[i] + '" aria-label="删除类型 ' + genres[i] + '">&times;</button></span>';
      }
      genreContainer.innerHTML = html;
      var btns = genreContainer.querySelectorAll('[data-remove-genre]');
      for (var i = 0; i < btns.length; i++) {
        btns[i].addEventListener('click', function() {
          var g = this.getAttribute('data-remove-genre');
          genres = genres.filter(function(genre) { return genre !== g; });
          renderGenreTags();
        });
      }
    }

    function addGenre() {
      var val = genreInput.value.trim().toLowerCase();
      if (val && genres.indexOf(val) === -1) {
        genres.push(val);
        renderGenreTags();
      }
      genreInput.value = '';
      genreInput.focus();
    }

    addGenreBtn.addEventListener('click', addGenre);
    genreInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); addGenre(); }
    });

    // slug 自动派生
    function deriveSlug(val) {
      return encodeURIComponent(val.trim());
    }

    titleEl.addEventListener('input', function() {
      if (autoSlugging) {
        slugEl.value = deriveSlug(titleEl.value);
        checkSlug();
      }
    });

    slugEl.addEventListener('input', function() {
      autoSlugging = false;
      checkSlug();
    });

    titleEl.addEventListener('blur', function() {
      autoSlugging = true;
    });

    function checkSlug() {
      var val = slugEl.value.trim();
      if (val && existingSlugs.indexOf(val) !== -1) {
        slugEl.classList.add('error');
        slugError.classList.remove('hidden');
        return false;
      }
      slugEl.classList.remove('error');
      slugError.classList.add('hidden');
      return true;
    }

    // 校验
    function validate() {
      var valid = true;

      if (!titleEl.value.trim()) {
        titleEl.classList.add('error');
        titleError.classList.remove('hidden');
        valid = false;
      } else {
        titleEl.classList.remove('error');
        titleError.classList.add('hidden');
      }

      if (!statusEl.value) {
        statusEl.classList.add('error');
        statusError.classList.remove('hidden');
        valid = false;
      } else {
        statusEl.classList.remove('error');
        statusError.classList.add('hidden');
      }

      var rv = ratingEl.value.trim();
      if (rv !== '') {
        var rn = Number(rv);
        if (!Number.isInteger(rn) || rn < 0 || rn > 10) {
          ratingEl.classList.add('error');
          ratingError.classList.remove('hidden');
          valid = false;
        } else {
          ratingEl.classList.remove('error');
          ratingError.classList.add('hidden');
        }
      } else {
        ratingEl.classList.remove('error');
        ratingError.classList.add('hidden');
      }

      if (!checkSlug()) valid = false;

      genBtn.disabled = !valid;
      return valid;
    }

    // 输入事件
    titleEl.addEventListener('input', validate);
    statusEl.addEventListener('change', validate);
    ratingEl.addEventListener('input', validate);

    // 生成 frontmatter
    function generate() {
      if (!validate()) return;

      var slug = slugEl.value.trim() || deriveSlug(titleEl.value);
      var fields = {
        titleCn: titleEl.value.trim(),
        titleJa: titlejaEl.value.trim() || undefined,
        status: statusEl.value,
        progress: Number(progressEl.value) || 0,
        episodes: episodesEl.value ? Number(episodesEl.value) : undefined,
        myRating: ratingEl.value ? Number(ratingEl.value) : undefined,
        comment: commentEl.value.trim() || undefined,
        cover: coverEl.value.trim() || undefined,
        airDate: airdateEl.value || undefined,
        genre: genres.length > 0 ? genres : undefined,
        draft: false,
      };

      // 生成 YAML
      var yaml = '---\n';
      var keys = ['titleCn', 'titleJa', 'status', 'progress', 'episodes', 'myRating', 'comment', 'cover', 'airDate', 'genre', 'draft'];
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        var v = fields[k];
        if (v === undefined) continue;
        if (Array.isArray(v)) {
          yaml += k + ':\n';
          for (var j = 0; j < v.length; j++) {
            yaml += '  - "' + v[j] + '"\n';
          }
        } else if (typeof v === 'string') {
          yaml += k + ': "' + v.replace(/"/g, '\\"') + '"\n';
        } else {
          yaml += k + ': ' + v + '\n';
        }
      }
      yaml += '---\n\n';
      yaml += bodyEl.value;

      // 生成 JSON
      var jsonFields = {};
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        if (fields[k] !== undefined) jsonFields[k] = fields[k];
      }
      jsonFields.body = bodyEl.value;
      var json = JSON.stringify(jsonFields, null, 2);

      // 展示预览
      previewContent.textContent = yaml;
      previewPanel.classList.remove('hidden');
      previewPanel.scrollIntoView({ behavior: 'smooth' });

      // 复制
      copyBtn.onclick = function() {
        navigator.clipboard.writeText(yaml).catch(function() {});
      };

      // 下载 JSON
      downloadBtn.onclick = function() {
        var blob = new Blob([json], { type: 'application/json' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = slug + '.json';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      };
    }

    form.addEventListener('submit', function(e) { e.preventDefault(); generate(); });

    // 初始化校验
    validate();
  })();
</script>
