---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import AnimeDetailHero from '../../../components/AnimeDetailHero.astro';
import Star from '../../../components/deco/Star.astro';
import Lightbox from '../../../components/Lightbox.astro';
import Heart from '../../../components/deco/Heart.astro';
import { render } from 'astro:content';
import { getAllAnime } from '../../../lib/anime';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const items = await getAllAnime();
  // Astro 路由层解码 URL 段后匹配，params.slug 必须用**未编码**的 titleCn（CJK 标题专用）。
  // 唯一性校验用原始 titleCn 即可，与解码值一致。
  const titles = items.map((a) => a.data.titleCn);
  if (new Set(titles).size !== titles.length) {
    const dupes = titles.filter((s, i) => titles.indexOf(s) !== i);
    throw new Error(`[anime] duplicate slug: ${[...new Set(dupes)].join(', ')}`);
  }
  return items.map((a) => ({
    params: { slug: a.data.titleCn },
    props: { entry: a },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'anime'> };
const { Content } = await render(entry);
const { titleCn, titleJa, cover, status, myRating, progress, episodes, airDate, comment, genre, screenshots } = entry.data;

// MDX body 为空的判定：entry.body（frontmatter 之外的原始 markdown）纯空白即视为无正文
const mdxEmpty = !entry.body?.trim();

const airDateStr = airDate?.toISOString().slice(0, 10);

const hasCover = cover != null && cover !== '';
const ogImage = typeof cover === 'string' ? cover : '/og-default.png';

const statusLabelMap = { watching: '在看', done: '做完', plan: '想看' } as const;
const description =
  comment ?? `${titleCn}，状态 ${statusLabelMap[status]}${myRating != null && myRating > 0 ? `，评分 ${myRating}/10` : ''}`;
---

<BaseLayout title={`${titleCn} · 追番记录`} description={description} ogImage={ogImage}>
  <Header />
  <main class="mx-auto max-w-[72rem] px-4 py-12 md:px-6">
    <Breadcrumb
      items={[
        { href: '/', label: '首页' },
        { href: '/anime', label: '追番' },
        { label: titleCn },
      ]}
    />

    <!-- Detail hero: two-column (≥md) / single-column (<md) -->
    <section class="mt-8 flex flex-col gap-8 md:flex-row">
      <!-- 左栏封面 -->
      <figure class="md:w-2/5">
        <div class="aspect-[2/3] w-full overflow-hidden rounded-[var(--radius-xl)] shadow-[var(--shadow-soft)]">
          {hasCover && typeof cover === 'string' ? (
            <img
              src={cover}
              alt={`${titleCn} 番剧封面`}
              loading="eager"
              fetchpriority="high"
              class="h-full w-full object-cover"
            />
          ) : cover && typeof cover !== 'string' ? (
            <Image
              src={cover as ImageMetadata}
              alt={`${titleCn} 番剧封面`}
              loading="eager"
              class="h-full w-full object-cover"
            />
          ) : (
            <div
              class="relative grid h-full w-full place-items-center"
              style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-deco-pink) 100%);"
              aria-hidden="true"
            >
              <Star class="floaty-a size-24 text-white/90 drop-shadow" />
              <Heart class="floaty-b absolute right-[16%] top-[20%] size-10 text-white/80 drop-shadow" />
              <Heart class="floaty-c absolute bottom-[18%] left-[18%] size-6 text-white/70" />
            </div>
          )}
        </div>
        <figcaption class="sr-only">{titleCn} 封面</figcaption>
      </figure>

      <!-- 右栏元信息卡 -->
      <div class="md:w-3/5">
        <AnimeDetailHero
          titleCn={titleCn}
          titleJa={titleJa}
          status={status}
          myRating={myRating}
          progress={progress ?? 0}
          episodes={episodes}
          airDate={airDateStr}
          comment={comment}
        />
      </div>
    </section>

    {/* 类型标签 */}
    {genre.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {genre.map((g) => (
          <a
            href={`/anime/genre/${encodeURIComponent(g)}`}
            class="rounded-full bg-[var(--color-surface-muted)] px-3 py-1 text-xs font-medium text-[var(--color-text-muted)] transition hover:bg-[var(--color-primary)] hover:text-[var(--color-primary-fg)]"
          >
            {g}
          </a>
        ))}
      </div>
    )}

    {/* 截图画廊 */}
    {screenshots.length > 0 && (
      <section class="mt-8">
        <h2 class="font-[family-name:var(--font-display)] text-xl font-semibold text-[var(--color-text)]">截图</h2>
        <div class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-3">
          {screenshots.map((shot) => (
            <img
              src={typeof shot === 'string' ? shot : shot.src}
              alt={`${titleCn} 截图`}
              class="aspect-video w-full cursor-zoom-in rounded-[var(--radius-md)] border border-[var(--color-border)] object-cover transition hover:opacity-90"
              loading="lazy"
              data-lightbox
            />
          ))}
        </div>
      </section>
    )}

    {/* MDX body（空则 fallback 文案） */}
    <div class="mt-12">
      {mdxEmpty ? (
        <p class="text-[var(--color-text-muted)]">这篇番感还没写，先看看基本信息吧…</p>
      ) : (
        <article class="prose">
          <Content />
        </article>
      )}
    </div>

    {/* 底栏返回 */}
    <nav class="mt-12">
      <a
        href="/anime"
        class="inline-flex items-center text-sm text-[var(--color-text-muted)] transition hover:text-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
      >
        ← 返回追番列表
      </a>
    </nav>
  </main>
  <Lightbox />
  <div class="mt-24">
    <Footer />
  </div>
</BaseLayout>

<style>
  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .floaty-a { animation: floaty 5s ease-in-out infinite; }
  .floaty-b { animation: floaty 3.6s ease-in-out infinite; }
  .floaty-c { animation: floaty 4.4s ease-in-out infinite 0.4s; }
  @media (prefers-reduced-motion: reduce) {
    .floaty-a, .floaty-b, .floaty-c { animation: none; }
  }
</style>
