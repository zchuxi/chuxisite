---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AnimeCard from '../../components/AnimeCard.astro';
import PillRow from '../../components/PillRow.astro';
import EmptyState from '../../components/EmptyState.astro';
import { Icon } from 'astro-icon/components';
import { getAllAnime, slugOf } from '../../lib/anime';

const items = await getAllAnime();
const genreCounts = new Map<string, number>();
for (const a of items)
  for (const g of a.data.genre)
    genreCounts.set(g, (genreCounts.get(g) ?? 0) + 1);
const genres = [...genreCounts.entries()].sort((a, b) => b[1] - a[1]);

const watching = items.filter((a) => a.data.status === 'watching').length;
const done = items.filter((a) => a.data.status === 'done').length;
const plan = items.filter((a) => a.data.status === 'plan').length;
const rated = items.filter((a) => a.data.myRating != null && a.data.myRating > 0);
const avgRating = rated.length > 0 ? (rated.reduce((s, a) => s + a.data.myRating!, 0) / rated.length).toFixed(1) : null;
---

<BaseLayout title="追番记录" description="在看 / 喝完 / 想看的番，评分、进度与短评都在这里">
  <Header />
  <main class="mx-auto max-w-[72rem] px-4 py-12 md:px-6">
    <p class="mt-4 text-sm text-[var(--color-text-muted)]">共 {items.length} 部 · 慢补番中～</p>

    {items.length > 0 && (
      <div class="relative mt-6 max-w-md">
        <Icon name="ph:magnifying-glass" class="pointer-events-none absolute left-3 top-1/2 size-5 -translate-y-1/2 text-[var(--color-text-muted)]" aria-hidden="true" />
        <input
          id="anime-search"
          type="search"
          aria-label="搜索番剧"
          placeholder="搜番名 / 类型…"
          class="w-full rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface)] py-3 pl-10 pr-4 text-[var(--color-text)] outline-none transition placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-primary)] focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
        />
      </div>
    )}

    {items.length > 0 && (
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-[var(--radius-md)] bg-[var(--color-surface-muted)] p-3 text-center">
          <p class="text-2xl font-bold text-[var(--color-primary)]">{items.length}</p>
          <p class="text-xs text-[var(--color-text-muted)]">总番数</p>
        </div>
        <div class="rounded-[var(--radius-md)] bg-[var(--color-surface-muted)] p-3 text-center">
          <p class="text-2xl font-bold text-[var(--color-success)]">{watching}</p>
          <p class="text-xs text-[var(--color-text-muted)]">在看</p>
        </div>
        <div class="rounded-[var(--radius-md)] bg-[var(--color-surface-muted)] p-3 text-center">
          <p class="text-2xl font-bold text-[var(--color-primary)]">{done}</p>
          <p class="text-xs text-[var(--color-text-muted)]">看完</p>
        </div>
        <div class="rounded-[var(--radius-md)] bg-[var(--color-surface-muted)] p-3 text-center">
          <p class="text-2xl font-bold text-[var(--color-text-muted)]">{plan}</p>
          <p class="text-xs text-[var(--color-text-muted)]">想看</p>
        </div>
        {avgRating && (
          <div class="col-span-full rounded-[var(--radius-md)] bg-[var(--color-surface-muted)] p-3 text-center sm:col-span-4">
            <p class="text-2xl font-bold text-[var(--color-deco-pink)]">{avgRating}</p>
            <p class="text-xs text-[var(--color-text-muted)]">平均分（{rated.length} 部已评分）</p>
          </div>
        )}
      </div>
    )}

    <PillRow
      class="mt-8"
      pills={[
        { href: '/anime', label: '全部', active: true },
        { href: '/anime/status/watching', label: '在看', active: false },
        { href: '/anime/status/done', label: '做完', active: false },
        { href: '/anime/status/plan', label: '想看', active: false },
      ]}
    />

    {genres.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {genres.map(([g, count]) => (
          <a
            href={`/anime/genre/${encodeURIComponent(g)}`}
            class="rounded-full bg-[var(--color-surface-muted)] px-3 py-1 text-xs font-medium text-[var(--color-text-muted)] transition hover:bg-[var(--color-primary)] hover:text-[var(--color-primary-fg)]"
          >
            {g} ({count})
          </a>
        ))}
      </div>
    )}

    {items.length === 0 ? (
      <EmptyState
        heading="追番清单还空空如也～ (｡･ω･｡)"
        body="还没录入任何番剧。先把最想补的番记下来吧～"
        ctaHref="/"
        ctaLabel="回到首页"
      />
    ) : (
      <section id="anime-grid" class="stagger-in mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-6 lg:grid-cols-3 lg:gap-8">
        {items.map((a) => (
          <AnimeCard
            href={`/anime/${slugOf(a.data.titleCn)}`}
            cover={a.data.cover}
            titleCn={a.data.titleCn}
            status={a.data.status}
            myRating={a.data.myRating}
            progress={a.data.progress}
            episodes={a.data.episodes}
            searchText={`${a.data.titleCn} ${a.data.titleJa ?? ''} ${a.data.genre.join(' ')}`}
          />
        ))}
      </section>
    )}

    <p id="anime-empty" class="mt-8 hidden text-center text-[var(--color-text-muted)]">没有匹配的番剧，换个关键词试试～</p>
  </main>
  <div class="mt-24">
    <Footer />
  </div>
</BaseLayout>

<script>
  (function() {
    var input = document.getElementById('anime-search');
    var grid = document.getElementById('anime-grid');
    var empty = document.getElementById('anime-empty');
    if (!input || !grid || !empty) return;

    var cards = Array.from(grid.querySelectorAll('[data-search]'));
    var emptyEl = empty;
    input.addEventListener('input', function() {
      var q = (input as HTMLInputElement).value.trim().toLowerCase();
      var visible = 0;
      cards.forEach(function(card) {
        var text = (card.getAttribute('data-search') || '').toLowerCase();
        var match = q === '' || text.includes(q);
        (card as HTMLElement).style.display = match ? '' : 'none';
        if (match) visible++;
      });
      emptyEl.classList.toggle('hidden', visible > 0);
    });
  })();
</script>
