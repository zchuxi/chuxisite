---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import IntroBlock from '../components/IntroBlock.astro';
import EntryCard from '../components/EntryCard.astro';
import Footer from '../components/Footer.astro';
import { getAllTools } from '../lib/tools';
import { getAllAnime } from '../lib/anime';

// 经 lib 薄封装读取种子（不直接 getCollection），入口卡以徽章展示当前收录数，证 lib→schema→页面管道通。
const tools = await getAllTools();
const anime = await getAllAnime();
---

<BaseLayout fullTitle="初曦的窝 · 工具、番剧、和一点点生活">
  <Header />
  <main>
    <Hero />
    <IntroBlock />
    <section
      class="mx-auto mt-12 grid max-w-[72rem] grid-cols-1 gap-[32px] px-4 md:grid-cols-2 md:px-6"
    >
      <EntryCard
        href="/tools"
        icon="ph:wrench"
        title="工具库"
        description="我收藏与折腾过的好用软件 / 网站，分类整理、图文记录"
        badge={`${tools.length} 个工具`}
        emphasis
      />
      <EntryCard
        href="/anime"
        icon="ph:television"
        title="追番记录"
        description="在看 / 看完 / 想看的番，评分、进度与短评都在这里"
        badge={`${anime.length} 部番剧`}
      />
    </section>
  </main>
  <Footer />
</BaseLayout>
