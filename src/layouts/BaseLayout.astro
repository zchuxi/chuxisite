---
import '../styles/global.css';

interface Props {
  title?: string;
  fullTitle?: string;
}
const { title, fullTitle: fullTitleProp } = Astro.props;
// D-02 SEO title 模式；首页用 fullTitle 直接覆盖（站名在前，避免生硬后缀）。完整 SEO/OG 块由 01-03 追加。
const fullTitle = fullTitleProp ?? (title ? `${title} · 初曦的窝` : '初曦的窝');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    {/* 首个 head 子元素：绘制前同步定主题，杜绝 FOUC（P3）。is:inline 让 Astro 原样内联不打包 */}
    <script is:inline>
      const t =
        localStorage.getItem('theme') ??
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (t === 'dark') document.documentElement.classList.add('dark');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
