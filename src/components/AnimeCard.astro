---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import StatusPill from './StatusPill.astro';

import RatingStar from './RatingStar.astro';
import Star from './deco/Star.astro';
import Heart from './deco/Heart.astro';

// 封面卡：整卡 <a> 包裹封面 + 信息区；StatusPill 作为 <a> 的兄弟绝对定位遮罩（不嵌套锚点）。
// 参考 EntryCard 双层链接模式；cover 缺失走 Blob 风格占位（青粉渐变 + 浮动星心，aria-hidden，CLS≈0）。
interface Props {
  href: string;
  cover?: ImageMetadata | string;
  titleCn: string;
  status: 'watching' | 'done' | 'plan';
  myRating?: number;
  progress?: number;
  episodes?: number;
}
const { href, cover, titleCn, status, myRating, progress = 0, episodes } = Astro.props;

const statusLabel: Record<string, string> = { watching: '在看', done: '做完', plan: '想看' };

// 进度文案 Copywriting 锁定
const progressText =
  status === 'plan'
    ? `全 ${episodes ?? '?'} 话 · 待补`
    : episodes != null
      ? `看到 ${progress} / 共 ${episodes} 话`
      : `已看 ${progress} 话`;

const ariaLabel = `${titleCn}，状态 ${statusLabel[status]}${myRating != null && myRating > 0 ? `，评分 ${myRating}/10` : ''}`;

const hasImage = cover != null && cover !== '';
---

<article
  class="group relative rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[var(--shadow-soft)] transition-transform duration-150 motion-safe:hover:-translate-y-0.5 hover:border-[var(--color-primary)]"
>
  <a
    href={href}
    aria-label={ariaLabel}
    class="block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 rounded-[var(--radius-lg)]"
  >
    <!-- 封面区：固定 aspect-[2/3] 保占位 CLS≈0 -->
    <div class="relative aspect-[2/3] w-full overflow-hidden rounded-t-[var(--radius-lg)]">
      {hasImage && typeof cover === 'string' ? (
        <img
          src={cover}
          alt={`${titleCn} 番剧封面`}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-150 motion-safe:group-hover:scale-[1.02]"
        />
      ) : hasImage ? (
        <Image
          src={cover}
          alt={`${titleCn} 番剧封面`}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-150 motion-safe:group-hover:scale-[1.02]"
        />
      ) : (
        <div
          class="grid h-full w-full place-items-center"
          style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-deco-pink) 100%);"
          aria-hidden="true"
        >
          <Star class="floaty-a size-24 text-white/90 drop-shadow" />
          <Heart class="floaty-b absolute right-[16%] top-[20%] size-10 text-white/80 drop-shadow" />
          <Heart class="floaty-c absolute bottom-[18%] left-[18%] size-6 text-white/70" />
        </div>
      )}
    </div>

    <!-- 信息区 -->
    <div class="p-3.5">
      <h3 class="truncate font-[family-name:var(--font-display)] text-lg font-semibold text-[var(--color-text)]">
        {titleCn}
      </h3>
      <div class="mt-1.5 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <RatingStar value={myRating ?? 0} />
        <span>{progressText}</span>
      </div>
    </div>
  </a>

  <!-- StatusPill 整卡 <a> 的兄弟绝对定位遮罩（仿 EntryCard 外链按钮）；pointer-events:none 点击穿透到 <a> -->
  <div class="pointer-events-none absolute right-2 top-2 z-10">
    <StatusPill status={status} />
  </div>
</article>

<style>
  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .floaty-a { animation: floaty 5s ease-in-out infinite; }
  .floaty-b { animation: floaty 3.6s ease-in-out infinite; }
  .floaty-c { animation: floaty 4.4s ease-in-out infinite 0.4s; }
  @media (prefers-reduced-motion: reduce) {
    .floaty-a, .floaty-b, .floaty-c { animation: none; }
  }
</style>
