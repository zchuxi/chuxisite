---
// 软萌四角星火花装饰。aria-hidden + currentColor（父级用 text-[var(--color-deco-pink)] 上色）。
// 定位/尺寸由父级 class 决定；装饰不占语义、不入 Tab 序。
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M12 0c1.1 7.3 3.6 9.8 10.9 10.9C15.6 12 13.1 14.5 12 21.8 10.9 14.5 8.4 12 1.1 10.9 8.4 9.8 10.9 7.3 12 0Z"
  ></path>
</svg>
