---
import Divider from './deco/Divider.astro';

const year = new Date().getFullYear();
---

<footer class="mt-24 bg-[var(--color-surface)]">
  <Divider class="h-6 w-full text-[var(--color-border)]" />
  <div
    class="mx-auto max-w-[72rem] px-4 pb-10 pt-4 text-center text-sm text-[var(--color-text-muted)] md:px-6"
  >
    <p>把喜欢的工具和番剧，慢慢收进这个小窝 ♡</p>
    <p class="mt-1">© {year} 初曦的窝</p>
    <nav class="mt-2 flex justify-center gap-4 text-xs">
      <a href="/timeline" class="transition hover:text-[var(--color-primary)]">最近更新</a>
      <a href="/rss.xml" class="transition hover:text-[var(--color-primary)]" target="_blank" rel="noopener">RSS</a>
    </nav>
  </div>
</footer>
