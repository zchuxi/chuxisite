---
import { Icon } from 'astro-icon/components';
import StatusPill from './StatusPill.astro';

// 详情页两栏右栏元信息卡（D-07 / D-08）。左栏封面由页面模板负责，避免 props 膨胀。
// Props 直接接收 anime entry 字段（ponytail：不复用精简数字版 RatingStar，Hero 需 5 独立 star 视觉）。
interface Props {
  titleCn: string;
  titleJa?: string;
  status: 'watching' | 'done' | 'plan';
  myRating?: number;
  progress: number;
  episodes?: number;
  airDate?: string;
  comment?: string;
}
const { titleCn, titleJa, status, myRating, progress, episodes, airDate, comment } = Astro.props;

const statusLabel: Record<string, string> = { watching: '在看', done: '做完', plan: '想看' };

// 进度文案 Copywriting 锁定（三形态）
const progressText =
  status === 'plan'
    ? `全 ${episodes ?? '?'} 话 · 待补`
    : episodes != null
      ? `看到 ${progress} / 共 ${episodes} 话`
      : `已看 ${progress} 话`;

// 5-star 映射：score/2 四舍五入取整（9/10 → 5 星；5/10 → 3 星；0/无 → 不渲染）
const filledStars = myRating != null && myRating > 0 ? Math.round(myRating / 2) : 0;

const metaGrid: { cond: boolean; text: string }[] = [
  { cond: episodes != null, text: `全 ${episodes} 话` },
  { cond: airDate != null, text: `开播 ${airDate}` },
];
---

<section
  class="rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[var(--shadow-soft)]"
>
  <h1 class="font-[family-name:var(--font-display)] text-[1.75rem] font-semibold text-[var(--color-text)]">
    {titleCn}
  </h1>

  {titleJa && (
    <p class="mt-1 text-sm italic text-[var(--color-text-muted)]">{titleJa}</p>
  )}

  <div class="mt-3">
    <StatusPill status={status} showIcon />
  </div>

  {filledStars > 0 && (
    <div
      class="mt-3 flex items-center gap-0.5"
      aria-label={`${titleCn} 评分 ${myRating} / 10`}
    >
      {[1, 2, 3, 4, 5].map((i) => (
        <Icon
          name="ph:star"
          class:list={['size-4', i <= filledStars ? 'star-fill' : 'star-empty']}
          aria-hidden="true"
        />
      ))}
      <span class="rating-num ml-1">★ {myRating}/10</span>
    </div>
  )}

  <dl class="mt-4 grid grid-cols-2 gap-2 text-sm text-[var(--color-text-muted)]">
    {metaGrid
      .filter((m) => m.cond)
      .map((m) => (
        <div class="flex items-center gap-2 rounded-[var(--radius-sm)] bg-[var(--color-surface-muted)] px-3 py-1.5">
          <dt class="sr-only">信息</dt>
          <dd>{m.text}</dd>
        </div>
      ))}
  </dl>

  <p class="mt-4 text-sm text-[var(--color-text-muted)]">{progressText}</p>

  {comment && (
    <blockquote class="mt-4 border-l-2 border-[var(--color-primary)] pl-3 text-sm italic text-[var(--color-text-muted)]">
      {comment}
    </blockquote>
  )}
</section>
